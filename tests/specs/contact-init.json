[
  {
    "name": "Contact Architect — empty state",
    "steps": [
      {
        "send": { "callback": "contact:init" },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText", "payload": { "text": "No architects available yet — check back soon." } }
        ]
      }
    ]
  },
  {
    "name": "Contact Architect — invalid architect ID",
    "steps": [
      {
        "send": { "callback": "contact:init:bad_id" },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText", "payload": { "text": "This profile is no longer available." } }
        ]
      }
    ]
  }
]
